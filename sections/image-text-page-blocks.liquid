<div class="custom-block-section page-width">
  {%- for block in section.blocks -%}
    <div class="block-row block-{{ block.id }}" {{ block.shopify_attributes }}>
      
      {%- case block.type -%}
        {%- when 'media_content' -%}
          <div class="media-container">
            {%- if block.settings.show_video and block.settings.video_url != blank or block.settings.video != blank -%}
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'block-video' }}
              {%- else -%}
                <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1" class="block-iframe"></iframe>
              {%- endif -%}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'block-image' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <div class="text-container">
            <h2 class="block-heading">{{ block.settings.heading }}</h2>
            <div class="block-description">{{ block.settings.text }}</div>
          </div>
      {%- endcase -%}
      
    </div>
  {%- endfor -%}
</div>

<style>
  .custom-block-section { padding: 20px 20px; }
  .block-row { 
    display: flex; 
    align-items: center; 
    gap: 70px; 
    margin-bottom: 50px; 
  }
  .media-container, .text-container { flex: 1; }
  .block-image, .block-video, .block-iframe { 
    width: 100%; 
    height: auto; 
    display: block; 
    border-radius: 8px; 
  }
  .block-iframe { aspect-ratio: 16/9; border: none; }
  .block-heading { font-size: 28px; margin-bottom: 15px; font-weight: bold; }
  .block-description { font-size: 20px; line-height: 1.6; color: #333; }

  @media screen and (max-width: 768px) {
    .block-row { flex-direction: column; gap: 20px; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "image-text-page-blocks",
  "settings": [],
  "blocks": [
    {
      "type": "media_content",
      "name": "Image/Video Row",
      "settings": [
        {
          "type": "header",
          "content": "Media Option"
        },
        {
          "type": "checkbox",
          "id": "show_video",
          "label": "Show Video instead of Image",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Upload Video (MP4)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Or YouTube/Vimeo URL",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "1. Keeps Food Fresh"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Stop throwing cash in the trash and meet the Chef Preserve.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "image-text-page-blocks",
      "blocks": [
        { "type": "media_content" }
      ]
    }
  ]
}
{% endschema %}