<section class="memories-section">
  <div class="memories-sec-container">
    <div class="section-header">
      <h2 class="heading">{{ section.settings.heading }}</h2>
      <p class="subheading">{{ section.settings.subheading }}</p>
    </div>

    
      <div class="cards-grid">
        {% for block in section.blocks %}
          {% if block.type == 'image_card' %}
            <!-- IMAGE CARD -->
            <div class="memory-card image-card" {{ block.shopify_attributes }}>
              <img src="{{ block.settings.image | image_url }}" alt="image">

              <div class="overlay">
                
               <div class="image-card-title"> {{ block.settings['title-1'] }} </div>
              <div class="image-card-text">  {{ block.settings['text-1'] }}</div>
              </div>
            </div>
          {% endif %}

          {% if block.type == 'text_card' %}
            <!-- TEXT CARD -->
            <div class="memory-card text-card" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <img class="icon" src="{{ block.settings.icon | image_url }}" alt="image">
              {% endif %}
              <div>

               <div class="text-card-title"> {{ block.settings.title }}</div>
               <div class="text-card-text"> {{ block.settings.text }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
   
  </div>
</section>

<style>
  .memories-section{
            font-family: "Iosevka Charon", monospace;
           background-color:rgb(236, 236, 226);
  }
  .memories-sec-container{
      width: 100%;
      max-width: 1300px;
      margin: 0 auto;
      padding: 15px 30px;
  }

.section-header .heading{
   font-size:60px;
    font-family: "Iosevka Charon", monospace;
    font-weight: 600;
    margin-bottom: 0;
   
}

.image-card-title{
  font-size:25px;
      font-weight: 800;
}
.image-card-text{
font-size:18px;
    line-height: 22px;
}

.text-card-title{
    font-size: 25px;
        font-weight: 800;
}




.section-header .subheading{
  font-size:35px;
  margin:0;
}

  /* GRID */
  .cards-grid {
       width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top:20px;
    padding:0;
  }

  /* CARD */
  .memory-card {
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }


.section-header{
text-align: center;
}


  /* IMAGE CARD */
  .image-card {
    height: 412px;
  }

  .image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* OVERLAY (main magic 🔥) */
  .overlay {
    position: absolute;
    bottom: 0;
    width: 100%;
    padding: 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: #fff;
        text-align: center;
  }

  /* richtext fix */
  .overlay p {
    margin: 0;
  }

  /* TEXT CARD */
  .text-card {
    background: #8B4513;
    color: #fff;
    padding: 30px 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .text-card img {
    width: 60px;
    margin: 0 auto 10px;
  }

  .text-card p {
    margin: 0;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
.section-header .heading {
    font-size: 44px;
}
.section-header .subheading {
    font-size: 24px;
}

.memories-sec-container {
     padding: 10px 12px;
}

  }
</style>

{% schema %}
{
  "name": "Memories Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR MEMORIES"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Scent & Memory"
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "title-1",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text-1",
          "label": "Text"
        }
      ]
    },

    {
      "type": "text_card",
      "name": "Text Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Memories Cards"
    }
  ]
}
{% endschema %}
