<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css">

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>


<div class="collection-slider-full-container">
<h1 class="text-collection-container">Shop by category</h1>
<div class="collection-main-container collection-slider">
    
{% for collection in collections %}
  
  <div class="collection-item">
    
    {% if collection.image %}
        <div class="collection-image-container">
            <div class="hover-img">
      <img src="{{ collection.image | img_url: 'medium' }}" alt="{{ collection.title }}">
      </div>
   </div>
    {% endif %}

   <div class="collection-div-container">
      <a href="{{ collection.url }}" class="collection-title-container">
        {{ collection.title }}
      </a>
  </div>




  </div>
  

{% endfor %}
</div>
</div>
<style>
    .collection-slider-full-container{
        width: 100%;
        background-color: #E9F0F2;
        padding-top: 50px;
        padding-bottom: 100px;
        margin-top: 60px;
    }
    .text-collection-container{
        text-align: center;
          font-family: "Poppins", sans-serif;
          font-weight: bold;
          font-size: 30px;
          padding-bottom: 10px;
    }
.collection-main-container{
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
   
}

.collection-image-container {
    width: 100%;
    max-width: 180px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid gray;

background-color: red;

   
}
.collection-div-container a{
text-decoration: none;
color: white;
font-weight: bold;
font-size: 13px;
  z-index: 2;
}
.collection-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
}
.hover-img {
    position: relative;
}
.hover-img::before {
    position: absolute;
    content: '';
    width: 100%;
    height: 100%;
    background-color: #00000060;
    border-radius: 100%;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    z-index: 1;
    margin: auto;
    visibility: hidden;
    transform: scale(0);
    opacity: 0;
    transition: all 0.3s ease-in-out;
}
.collection-image-container:hover .hover-img::before  {
    visibility: visible;
    transform: scale(1);
    opacity: 1;
    transition: all 0.3s ease-in-out;
}

.collection-item {
    position: relative;
}

.collection-div-container{
position: absolute;
opacity: 0;
 position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
   display: flex;
    justify-content: center;
    align-items: center;
z-index: 2;

     
}
.collection-item:hover .collection-div-container{
  opacity: 1;
}


  {% comment %} .collection-slider-full-container .slick-prev{
   
    width: 30px;
    height: 30px;
    padding: 0;
    border-radius: 50%;
    background-color: yellow;
}
   .collection-slider-full-container .slick-next{
        width: 30px;
    height: 30px;
    padding: 0;
    border-radius: 50%;
    background-color: yellow;
  } {% endcomment %}
 
 .collection-slider-full-container .slick-prev:before, 
  .collection-slider-full-container .slick-next:before {
  color: #000;
  width: 40px !important;
  height: 40px !important;
  font-size: 35px;
  }


@media (min-width: 375px) and (max-width: 768px) {
  .collection-image-container {

    max-width: 163px;
}
.text-collection-container {
    font-size: 19px;
    padding-bottom: 5px;
}
.collection-slider-full-container {
  
    padding-top: 17px;
    padding-bottom: 40px;
    margin-top: 36px;
}


}


@media (min-width: 300px) and (max-width: 320px) {
 .collection-image-container {
        max-width: 135px;
}
}

   

</style>



<script>

   $(document).ready(function () {
   $('.collection-slider').slick({
  dots: false,
  infinite: true,
  speed: 300,
  arrows: true,
  slidesToShow: 6,
  slidesToScroll: 2,
  autoplay: true,
  autoplaySpeed: 2000,
  responsive: [
    {
      breakpoint: 1024,
      settings: {
        slidesToShow: 8,
        slidesToScroll:1,
        infinite: true,
        dots: true,
        
      }
    },
    {
      breakpoint: 768,
      settings: {
        slidesToShow: 2,
        slidesToScroll: 1
      }
    },
   {
      breakpoint:1024,
      settings: {
        slidesToShow: 3,
        slidesToScroll: 1
      }
    },
    {
      breakpoint: 1440,
      settings: {
        slidesToShow: 5,
        slidesToScroll: 1
      }
    },
  ]
});
  });
				
</script>


{% schema %}
{
    "name": "collection-slider",
    "settings": [],
    "presets": [
        {
            "name": "collection-slider"
        }
    ]
}
{% endschema %}