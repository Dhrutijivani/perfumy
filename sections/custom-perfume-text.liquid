<div class="perfume-text-section text-{{ section.settings.alignment }}">
  <div class="perfume-text-container">
    {% if section.settings.sub_heading != blank %}
      <span class="perfume-subheading">{{ section.settings.sub_heading }}</span>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="perfume-main-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="perfume-description">
        {{ section.settings.description }}
      </div>
    {% endif %}
  </div>
</div>

{% style %}
.perfume-text-section {
  padding: 60px 20px;
  background-color: {{ section.settings.bg_color }};
}
.perfume-text-container {
  max-width: 800px;
  margin: 0 auto;
}
.perfume-subheading {
  display: block;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #888;
  margin-bottom: 15px;
}
.perfume-main-heading {
  font-size: 36px;
  font-family: 'Playfair Display', serif; /* Luxury Serif Font */
  color:#bda5a5;
  margin-bottom: 20px;
  font-weight: 400;
  line-height: 1.3;
}
.perfume-description {
  font-size: 16px;
  color: #555;
  line-height: 1.6;
}

/* Mobile Responsive */
@media screen and (max-width: 749px) {
  .perfume-text-section {
    padding: 40px 15px;
  }
  .perfume-main-heading {
    font-size: 28px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Perfume Simple Text",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Elegance in a Bottle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Crafted for the Modern Connoisseur"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Experience a sophisticated blend of rare oud, French lavender, and warm amber notes designed to leave an unforgettable impression.</p>"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Perfume Simple Text"
    }
  ]
}
{% endschema %}