<div class="dynamic-media-section page-width">
  {% for block in section.blocks %}
    <div class="media-text-row {% if block.settings.layout == 'right' %}row-reverse{% endif %}" {{ block.shopify_attributes }}>
      
      <div class="media-column">
        {%- if block.settings.show_video -%}
          <div class="video-wrapper">
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'media-element' }}
            {%- elsif block.settings.video_url != blank -%}
              <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}" class="media-element" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'media-element', loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg media-element' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="text-column">
        <div class="text-content">
          <h2 class="heading">{{ block.settings.heading }}</h2>
          <div class="description">{{ block.settings.description }}</div>
        </div>
      </div>

    </div>
  {% endfor %}
</div>

<style>
  .dynamic-media-section { padding: 5px 20px; max-width: 1200px; margin: 0 auto; }
  .media-text-row { display: flex; align-items: center; gap: 70px; margin-bottom: 80px; }
  .media-text-row.row-reverse { flex-direction: row-reverse; }
  
  .media-column, .text-column { flex: 1; width: 50%; }
  
  .media-element { width: 100%; height: 150px; display: block; border-radius: 4px; object-fit: cover; }
  .video-wrapper { position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden; }
  .video-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }

  .text-content { padding: 20px 0; }
  .heading { font-size: 28px; font-weight: 700; margin-bottom: 20px; color: #000; line-height: 1.2; }
  .description { font-size: 20px; line-height: 1.6; color: #333; }
  .description strong { color: #000; font-weight: 700; }

  @media screen and (max-width: 768px) {
    .media-text-row, .media-text-row.row-reverse { flex-direction: column; gap: 30px; margin-bottom: 60px; }
    .media-column, .text-column { width: 100%; }
    .heading { font-size: 22px; }
    .description { font-size: 16px; }
  }
</style>

{% schema %}
{
  "name": "Dynamic Media Row page",
  "settings": [],
  "blocks": [
    {
      "type": "row",
      "name": "Media + Text Row",
      "settings": [
        {
          "type": "select",
          "id": "layout",
          "label": "Desktop Media Alignment",
          "options": [
            { "value": "left", "label": "Media Left" },
            { "value": "right", "label": "Media Right" }
          ],
          "default": "left"
        },
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "checkbox",
          "id": "show_video",
          "label": "Use Video instead of Image",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify Video (MP4)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "YouTube/Vimeo URL",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "header",
          "content": "Text Settings"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "2. Saves Money by Reducing Food Waste."
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p><strong>Chef Preserve helps keep your food fresh</strong>, so you can reduce waste and save money.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dynamic Media Row page",
      "blocks": [
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}