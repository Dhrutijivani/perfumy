<section class="git-practice">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.description }}</p>

    <a href="{{ section.settings.button_link }}" class="git-btn">
      {{ section.settings.button_text }}
    </a>
  </div>
</section>

<style>
.git-practice {
  padding: 60px 20px;
  background: #f5f5f5;
  text-align: center;
}

.git-practice h2 {
  font-size: 32px;
  margin-bottom: 10px;
}

.git-practice p {
  font-size: 16px;
  margin-bottom: 20px;
}

.git-btn {
  display: inline-block;
  padding: 12px 24px;
  background: #d9d1d1;
  color: #fff;
  text-decoration: none;
  border-radius: 6px;
}
</style>

{% schema %}
{
  "name": "Git Practice",
  "tag": "section",
  "class": "git-practice-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Git Practice Section"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "This section is created for Git learning."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn GitHub"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Git Practice"
    }
  ]
}
{% endschema %}