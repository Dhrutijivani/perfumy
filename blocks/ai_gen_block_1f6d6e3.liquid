{% doc %}
  @prompt
    A timer should run in this, and I should be able to set the time as well.Create a section exactly the same as the image.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-countdown-timer__value-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    background-color: {{ block.settings.number_bg_color }};
    padding: {{ block.settings.number_padding }}px;
    border-radius: {{ block.settings.number_border_radius }}px;
    min-width: {{ block.settings.number_min_width }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin-top: {{ block.settings.label_spacing }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    font-size: {{ block.settings.expired_text_size }}px;
    color: {{ block.settings.expired_text_color }};
    padding: 20px;
    display: none;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__value-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
      padding: calc({{ block.settings.number_padding }}px * 0.8);
      min-width: calc({{ block.settings.number_min_width }}px * 0.8);
    }

    .ai-countdown-timer__label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.9);
    }

    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}">
    {% if block.settings.show_days %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="days">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="hours">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_minutes %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="minutes">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_seconds %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-unit="seconds">00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
      </div>
    {% endif %}
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        if (!this.endDate || !this.endTime) {
          return;
        }

        const endDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();

        const updateTimer = () => {
          const now = new Date().getTime();
          const distance = endDateTime - now;

          if (distance < 0) {
            if (this.interval) {
              clearInterval(this.interval);
            }
            this.querySelector('.ai-countdown-timer__display-{{ ai_gen_id }}').style.display = 'none';
            this.querySelector('.ai-countdown-timer__expired-{{ ai_gen_id }}').classList.add('active');
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          const daysEl = this.querySelector('[data-unit="days"]');
          const hoursEl = this.querySelector('[data-unit="hours"]');
          const minutesEl = this.querySelector('[data-unit="minutes"]');
          const secondsEl = this.querySelector('[data-unit="seconds"]');

          if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
          if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
          if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
          if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
        };

        updateTimer();
        this.interval = setInterval(updateTimer, 1000);
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

