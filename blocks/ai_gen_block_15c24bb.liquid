{% doc %}
  @prompt
    Create a product promotional banner section that matches this design: a horizontally split card with a green border and light gray background. Left side shows a product image. Right side contains: a bold red "SALE ENDS SOON" heading, a live countdown timer with hours/minutes/seconds displayed in red rounded boxes with labels below, a product name in dark text, a large red CTA button with discount text (e.g. "GET 61% OFF"), and two lines of small text showing "Sell-out Risk: High | FREE shipping" (with "High" and "FREE" in bold red) and "60-Day Money Back Guarantee!". Include customizable settings for: product image, sale heading text, countdown end date, CTA button text and link, product name, discount percentage, guarantee text, sellout risk level. Include a live countdown timer using JavaScript. Make it fully responsive - stack vertically on mobile., A timer should run in this, and I should be able to set the time as well.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-promo-banner-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-promo-banner-image-section-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-promo-banner-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-promo-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-promo-banner-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-promo-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-promo-banner-content-section-{{ ai_gen_id }} {
    flex: 1;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
  }

  .ai-promo-banner-sale-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.sale_heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.sale_heading_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-promo-banner-countdown-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
  }

  .ai-promo-banner-countdown-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .ai-promo-banner-countdown-value-{{ ai_gen_id }} {
    background-color: {{ block.settings.countdown_bg_color }};
    color: {{ block.settings.countdown_text_color }};
    font-size: {{ block.settings.countdown_number_size }}px;
    font-weight: 700;
    padding: 12px 16px;
    border-radius: {{ block.settings.countdown_border_radius }}px;
    min-width: 60px;
    text-align: center;
  }

  .ai-promo-banner-countdown-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_label_size }}px;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    font-weight: 500;
  }

  .ai-promo-banner-product-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-promo-banner-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 700;
    padding: 16px 32px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    text-decoration: none;
    text-align: center;
    transition: transform 0.2s ease;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-promo-banner-cta-button-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  .ai-promo-banner-info-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.info_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-promo-banner-info-text-{{ ai_gen_id }} strong {
    color: {{ block.settings.highlight_color }};
    font-weight: 700;
  }

  .ai-promo-banner-guarantee-{{ ai_gen_id }} {
    font-size: {{ block.settings.info_text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-promo-banner-container-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-promo-banner-content-section-{{ ai_gen_id }} {
      padding: 24px;
      gap: 20px;
    }

    .ai-promo-banner-sale-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.sale_heading_size }}px * 0.8);
    }

    .ai-promo-banner-countdown-value-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.countdown_number_size }}px * 0.8);
      padding: 10px 12px;
      min-width: 50px;
    }

    .ai-promo-banner-countdown-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.countdown_label_size }}px * 0.9);
    }

    .ai-promo-banner-product-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.product_name_size }}px * 0.85);
    }

    .ai-promo-banner-cta-button-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.cta_font_size }}px * 0.9);
      padding: 14px 28px;
    }

    .ai-promo-banner-image-placeholder-{{ ai_gen_id }} {
      min-height: 250px;
    }
  }
{% endstyle %}

{% liquid
  assign end_date = block.settings.countdown_end_date
  assign end_time = block.settings.countdown_end_time
  
  if end_date != blank and end_time != blank
    assign countdown_datetime = end_date | append: ' ' | append: end_time
  elsif end_date != blank
    assign countdown_datetime = end_date | append: ' 23:59:59'
  else
    assign countdown_datetime = ''
  endif
%}

<promo-banner-{{ ai_gen_id }}
  class="ai-promo-banner-{{ ai_gen_id }}"
  data-end-date="{{ countdown_datetime }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-promo-banner-container-{{ ai_gen_id }}">
    <div class="ai-promo-banner-image-section-{{ ai_gen_id }}">
      <div class="ai-promo-banner-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
            class="ai-promo-banner-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-promo-banner-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-promo-banner-content-section-{{ ai_gen_id }}">
      {% if block.settings.sale_heading != blank %}
        <h2 class="ai-promo-banner-sale-heading-{{ ai_gen_id }}">
          {{ block.settings.sale_heading }}
        </h2>
      {% endif %}

      <div class="ai-promo-banner-countdown-{{ ai_gen_id }}">
        <div class="ai-promo-banner-countdown-item-{{ ai_gen_id }}">
          <div class="ai-promo-banner-countdown-value-{{ ai_gen_id }}" data-countdown-hours>00</div>
          <div class="ai-promo-banner-countdown-label-{{ ai_gen_id }}">Hours</div>
        </div>
        <div class="ai-promo-banner-countdown-item-{{ ai_gen_id }}">
          <div class="ai-promo-banner-countdown-value-{{ ai_gen_id }}" data-countdown-minutes>00</div>
          <div class="ai-promo-banner-countdown-label-{{ ai_gen_id }}">Minutes</div>
        </div>
        <div class="ai-promo-banner-countdown-item-{{ ai_gen_id }}">
          <div class="ai-promo-banner-countdown-value-{{ ai_gen_id }}" data-countdown-seconds>00</div>
          <div class="ai-promo-banner-countdown-label-{{ ai_gen_id }}">Seconds</div>
        </div>
      </div>

      {% if block.settings.product_name != blank %}
        <h3 class="ai-promo-banner-product-name-{{ ai_gen_id }}">
          {{ block.settings.product_name }}
        </h3>
      {% endif %}

      {% if block.settings.cta_button_text != blank %}
        <a
          href="{{ block.settings.cta_button_link }}"
          class="ai-promo-banner-cta-button-{{ ai_gen_id }}"
        >
          {{ block.settings.cta_button_text }}
        </a>
      {% endif %}

      <div class="ai-promo-banner-info-text-{{ ai_gen_id }}">
        Sell-out Risk: <strong>{{ block.settings.sellout_risk }}</strong> | <strong>FREE</strong> shipping
      </div>

      {% if block.settings.guarantee_text != blank %}
        <div class="ai-promo-banner-guarantee-{{ ai_gen_id }}">
          {{ block.settings.guarantee_text }}
        </div>
      {% endif %}
    </div>
  </div>
</promo-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = null;
        this.countdownInterval = null;
      }

      connectedCallback() {
        const endDateStr = this.dataset.endDate;
        if (endDateStr) {
          this.endDate = new Date(endDateStr).getTime();
          if (!isNaN(this.endDate)) {
            this.startCountdown();
          }
        }
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.countdownInterval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const now = new Date().getTime();
        const distance = this.endDate - now;

        if (distance < 0) {
          if (this.countdownInterval) {
            clearInterval(this.countdownInterval);
          }
          this.setCountdownValues(0, 0, 0);
          return;
        }

        const hours = Math.floor(distance / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.setCountdownValues(hours, minutes, seconds);
      }

      setCountdownValues(hours, minutes, seconds) {
        const hoursEl = this.querySelector('[data-countdown-hours]');
        const minutesEl = this.querySelector('[data-countdown-minutes]');
        const secondsEl = this.querySelector('[data-countdown-seconds]');

        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      }
    }

    customElements.define('promo-banner-{{ ai_gen_id }}', PromoBanner{{ ai_gen_id }});
  })();
</script>

