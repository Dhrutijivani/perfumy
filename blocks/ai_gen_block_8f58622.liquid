{% doc %}
  @prompt
    Create a Shopify custom section that replicates a long-form product feature layout based on a high-converting advertorial style.
    
    The section should display 10 feature blocks in sequence, combining two reference layouts into one continuous section.
    
    Structure:
    - Each feature block contains:
      - An image on one side
      - Text content on the other side
    - Alternate layout:
      - First block: image left, text right
      - Second block: image right, text left
      - Continue alternating for all items
    
    Content:
    - Each block should include:
      - Numbered heading (e.g., "1. Keeps Food Fresh")
      - Short description paragraph
    - Include total 10 sections (like a list of reasons)
    
    Special elements:
    - Include one multi-image grid (for step-by-step usage)
    - Include one testimonial-style image grid
    - Include one bonus section at the end with:
      - Warranty badge image
      - "Bonus Reason" heading
      - Short promotional text
    
    Design:
    - Clean, modern, high-converting landing page style
    - Proper spacing between sections
    - Images with rounded corners
    - Text aligned neatly with good readability
    - Use a max-width container and center the content
    
    Responsive:
    - On mobile:
      - Stack image and text vertically
      - Maintain spacing and readability
    
    Functionality:
    - All images should be changeable in Shopify editor
    - All headings and text should be editable
    - Allow adding/removing blocks dynamically
    
    Important:
    - Combine both layouts into ONE continuous section
    - Maintain consistent spacing and alignment throughout
    - Do not create multiple sections
    
    Return complete Liquid + CSS code   Make the design visually similar to a high-converting product advertorial landing page with alternating image-text layout., Show the number and heading side by side, and in one section add a video instead of an image., Show the number in black color and bold, and make the number’s font size adjustable., Show a video in the first one.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-features-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-product-features-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-product-features-item-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.item_gap }}px;
    align-items: center;
    margin-bottom: {{ block.settings.item_spacing }}px;
  }

  .ai-product-features-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-product-features-item-{{ ai_gen_id }}.reverse {
    direction: rtl;
  }

  .ai-product-features-item-{{ ai_gen_id }}.reverse > * {
    direction: ltr;
  }

  .ai-product-features-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-product-features-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-product-features-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-product-features-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-product-features-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-features-placeholder-message-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(255, 255, 255, 0.9);
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-product-features-content-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-product-features-title-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .ai-product-features-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 900;
    color: #000000;
    flex-shrink: 0;
  }

  .ai-product-features-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.3;
    flex: 1;
  }

  .ai-product-features-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-product-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_columns }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.item_spacing }}px;
  }

  .ai-product-features-grid-item-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-product-features-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-product-features-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-features-grid-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-features-bonus-{{ ai_gen_id }} {
    background-color: {{ block.settings.bonus_bg_color }};
    border-radius: {{ block.settings.bonus_border_radius }}px;
    padding: {{ block.settings.bonus_padding }}px;
    text-align: center;
    margin-top: {{ block.settings.item_spacing }}px;
  }

  .ai-product-features-bonus-badge-{{ ai_gen_id }} {
    width: {{ block.settings.bonus_badge_size }}px;
    height: auto;
    margin: 0 auto 20px;
    display: block;
  }

  .ai-product-features-bonus-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.bonus_badge_size }}px;
    height: {{ block.settings.bonus_badge_size }}px;
    background-color: #f4f4f4;
    border-radius: 50%;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-features-bonus-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-product-features-bonus-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.bonus_heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.bonus_heading_color }};
    margin: 0 0 16px 0;
  }

  .ai-product-features-bonus-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.bonus_text_size }}px;
    color: {{ block.settings.bonus_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-product-features-item-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-product-features-item-{{ ai_gen_id }}.reverse {
      direction: ltr;
    }

    .ai-product-features-content-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-product-features-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-product-features-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-product-features-bonus-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.bonus_heading_size }}px * 0.85);
    }

    .ai-product-features-title-wrapper-{{ ai_gen_id }} {
      gap: 8px;
    }
  }
{% endstyle %}

<product-features-{{ ai_gen_id }} class="ai-product-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-features-container-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign feature_enabled_key = 'feature_' | append: i | append: '_enabled'
        assign feature_image_key = 'feature_' | append: i | append: '_image'
        assign feature_video_key = 'feature_' | append: i | append: '_video'
        assign feature_number_key = 'feature_' | append: i | append: '_number'
        assign feature_heading_key = 'feature_' | append: i | append: '_heading'
        assign feature_description_key = 'feature_' | append: i | append: '_description'

        assign feature_enabled = block.settings[feature_enabled_key]
        assign feature_image = block.settings[feature_image_key]
        assign feature_video = block.settings[feature_video_key]
        assign feature_number = block.settings[feature_number_key]
        assign feature_heading = block.settings[feature_heading_key]
        assign feature_description = block.settings[feature_description_key]

        assign is_even = i | modulo: 2
      %}

      {% if feature_enabled %}
        <div class="ai-product-features-item-{{ ai_gen_id }} {% if is_even == 0 %}reverse{% endif %}">
          <div class="ai-product-features-image-wrapper-{{ ai_gen_id }}">
            {% if feature_video %}
              {{
                feature_video
                | video_tag:
                  image_size: '800x',
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: true,
                  class: 'ai-product-features-video-' | append: ai_gen_id
              }}
            {% elsif feature_image %}
              <img
                src="{{ feature_image | image_url: width: 800 }}"
                alt="{{ feature_heading | escape }}"
                loading="lazy"
                width="{{ feature_image.width }}"
                height="{{ feature_image.height }}"
                class="ai-product-features-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-product-features-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-product-features-placeholder-message-{{ ai_gen_id }}">
                  {% if i == 1 %}
                    Add a video or image for Feature {{ i }}
                  {% else %}
                    Add an image for Feature {{ i }}
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>

          <div class="ai-product-features-content-{{ ai_gen_id }}">
            {% if feature_number != blank or feature_heading != blank %}
              <div class="ai-product-features-title-wrapper-{{ ai_gen_id }}">
                {% if feature_number != blank %}
                  <span class="ai-product-features-number-{{ ai_gen_id }}">{{ feature_number }}</span>
                {% endif %}
                {% if feature_heading != blank %}
                  <h3 class="ai-product-features-heading-{{ ai_gen_id }}">{{ feature_heading }}</h3>
                {% endif %}
              </div>
            {% endif %}
            {% if feature_description != blank %}
              <div class="ai-product-features-description-{{ ai_gen_id }}">{{ feature_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% if block.settings.show_image_grid %}
      <div class="ai-product-features-grid-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign grid_image_key = 'grid_image_' | append: i
            assign grid_image = block.settings[grid_image_key]
          %}

          <div class="ai-product-features-grid-item-{{ ai_gen_id }}">
            {% if grid_image %}
              <img
                src="{{ grid_image | image_url: width: 400 }}"
                alt="Step {{ i }}"
                loading="lazy"
                width="{{ grid_image.width }}"
                height="{{ grid_image.height }}"
                class="ai-product-features-grid-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-product-features-grid-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if block.settings.show_testimonial_grid %}
      <div class="ai-product-features-grid-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign testimonial_image_key = 'testimonial_image_' | append: i
            assign testimonial_image = block.settings[testimonial_image_key]
          %}

          <div class="ai-product-features-grid-item-{{ ai_gen_id }}">
            {% if testimonial_image %}
              <img
                src="{{ testimonial_image | image_url: width: 400 }}"
                alt="Testimonial {{ i }}"
                loading="lazy"
                width="{{ testimonial_image.width }}"
                height="{{ testimonial_image.height }}"
                class="ai-product-features-grid-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-product-features-grid-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if block.settings.show_bonus %}
      <div class="ai-product-features-bonus-{{ ai_gen_id }}">
        {% if block.settings.bonus_badge %}
          <img
            src="{{ block.settings.bonus_badge | image_url: width: 200 }}"
            alt="{{ block.settings.bonus_heading | escape }}"
            loading="lazy"
            width="{{ block.settings.bonus_badge.width }}"
            height="{{ block.settings.bonus_badge.height }}"
            class="ai-product-features-bonus-badge-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-product-features-bonus-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.bonus_heading != blank %}
          <h3 class="ai-product-features-bonus-heading-{{ ai_gen_id }}">{{ block.settings.bonus_heading }}</h3>
        {% endif %}
        {% if block.settings.bonus_text != blank %}
          <div class="ai-product-features-bonus-text-{{ ai_gen_id }}">{{ block.settings.bonus_text }}</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</product-features-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductFeatures{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('product-features-{{ ai_gen_id }}', ProductFeatures{{ ai_gen_id }});
  })();
</script>

